@{
    ViewData["Title"] = "GitHub";
}

<div class="mb-4">
    <h2 class="mb-0">GitHub</h2>
    <p class="text-muted mb-0">Consultar perfil público de usuario</p>
</div>

<div class="row justify-content-center">
    <div class="col-md-6">
        <div class="card shadow-sm mb-4">
            <div class="card-body">
                <div class="input-group">
                    <span class="input-group-text">
                        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" class="bi bi-github" viewBox="0 0 16 16">
                            <path d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27s1.36.09 2 .27c1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.01 8.01 0 0 0 16 8c0-4.42-3.58-8-8-8"/>
                        </svg>
                    </span>
                    <input type="text" class="form-control" id="inputUsername" placeholder="Nombre de usuario (ej: torvalds)" />
                    <button class="btn btn-dark" id="btnBuscar">
                        <span id="buscarSpinner" class="spinner-border spinner-border-sm me-1 d-none" role="status"></span>
                        Buscar
                    </button>
                </div>
                <div id="buscarError" class="text-danger small mt-2" style="display:none"></div>
            </div>
        </div>

        <div id="perfilCard" style="display:none">
            <div class="card shadow-sm">
                <div class="card-body text-center py-4">
                    <img id="perfilAvatar" src="" alt="Avatar" class="rounded-circle mb-3" width="90" height="90" />
                    <h4 id="perfilName" class="mb-0"></h4>
                    <p id="perfilLogin" class="text-muted mb-3"></p>
                    <div class="d-flex justify-content-center gap-4 mb-3">
                        <div>
                            <div class="fw-bold fs-5" id="perfilRepos">0</div>
                            <div class="text-muted small">Repositorios</div>
                        </div>
                        <div class="border-start"></div>
                        <div>
                            <div class="fw-bold fs-5" id="perfilFollowers">0</div>
                            <div class="text-muted small">Seguidores</div>
                        </div>
                    </div>
                    <a id="perfilLink" href="#" target="_blank" class="btn btn-outline-dark btn-sm">
                        Ver perfil en GitHub
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="~/js/GitHub/GitHub.js" asp-append-version="true"></script>
}
